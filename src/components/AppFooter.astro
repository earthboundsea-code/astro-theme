---
import Container from "./Container.astro";
---

<footer class="py-12 bg-[#0a0a0a] border-t border-white/10">
    <Container>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 pb-12">
        <div class="flex flex-col gap-4">
          <h2 class="text-2xl font-bold text-white tracking-tight">GrowUpward</h2>
          <p class="text-gray-400 text-sm max-w-xs">
            Advancing Cyber-Resilience for Thailand and Beyond. Empowering digital safety in 2026.
          </p>
        </div>

        <div class="flex flex-col gap-4">
          <span class="text-xs font-mono text-cyan-400 uppercase tracking-widest">Navigation</span>
          <nav class="flex flex-col gap-3">
            <a href="/" class="text-gray-400 hover:text-white transition text-sm">Home</a>
            <a href="/#insights" class="text-gray-400 hover:text-white transition text-sm">Insights</a>
            <a href="/about" class="text-gray-400 hover:text-white transition text-sm">About Us</a>
          </nav>
        </div>

        <div class="flex flex-col gap-4">
          <span class="text-xs font-mono text-cyan-400 uppercase tracking-widest">Connect With Us</span>
          <div class="grid grid-cols-2 gap-4">
            <a href="https://www.instagram.com/growupward_th/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-gray-400 hover:text-white transition text-sm">
               <span class="p-1.5 bg-white/5 rounded">IG</span> Instagram
            </a>
            <a href="https://www.linkedin.com/company/growupward" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-gray-400 hover:text-white transition text-sm">
               <span class="p-1.5 bg-white/5 rounded">LI</span> LinkedIn
            </a>
            <a href="https://line.me/R/ti/p/@466yghpn" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-gray-400 hover:text-white transition text-sm">
               <span class="p-1.5 bg-white/5 rounded text-[10px]">LN</span> Line
            </a>
            <a href="mailto:contact@growupward.io" class="flex items-center gap-2 text-gray-400 hover:text-white transition text-sm">
               <span class="p-1.5 bg-white/5 rounded">@</span> contact@growupward.io
            </a>
          </div>
        </div>
      </div>

      <div class="pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-6">
        <div class="flex flex-col md:flex-row items-center gap-4 md:gap-8">
          <span class="text-gray-500 text-xs">GrowUpward &copy; 2026. All rights reserved.</span>
          <div class="flex gap-4">
            <a href="#" class="text-gray-500 hover:text-gray-300 text-xs transition">Terms</a>
            <a href="#" class="text-gray-500 hover:text-gray-300 text-xs transition">Privacy</a>
          </div>
        </div>

        <div class="flex items-center gap-3">
          <span class="text-[10px] font-mono text-gray-600 uppercase tracking-tighter">Language</span>
          <select class="bg-transparent border border-white/10 rounded px-2 py-1 text-xs text-gray-400 outline-none focus:border-cyan-400 transition cursor-pointer appearance-none">
            <option value="en" class="bg-[#0a0a0a]">English (EN)</option>
            <option value="th" class="bg-[#0a0a0a]">ไทย (TH)</option>
          </select>
        </div>
      </div>
    </Container>
</footer>
