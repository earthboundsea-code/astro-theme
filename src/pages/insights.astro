---
import Layout from '../layouts/Layout.astro';
import Container from '../components/Container.astro';

const insights = [
  {
    id: "womens-day",
    title: "Happy International Women’s Day! 🎉",
    category: "Company News",
    date: "March 8, 2026",
    image: "https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?q=80&w=1976&auto=format&fit=crop",
    description: "Women remain underrepresented in the cybersecurity industry worldwide. Globally, women make up approximately 24% of the cybersecurity workforce...",
    fullContent: `Women remain underrepresented in the cybersecurity industry worldwide. Globally, women make up approximately 24% of the cybersecurity workforce, reflecting a significant gender gap in one of the fastest-growing sectors of the digital economy.<br/><br/>In Thailand, the gender gap in cybersecurity is even more pronounced. Women represent only a small fraction of professionals in the field, estimated at around 3%. While women participate actively in the broader technology and digital economy, cybersecurity remains a specialized field where female representation is still developing. Expanding education, visibility, and mentorship opportunities will be essential to encourage more women to enter the sector.<br/><br/>As cyber threats continue to evolve globally, diversity within cybersecurity teams becomes increasingly important. Encouraging more women to pursue careers in cybersecurity will not only help address the global talent shortage but also strengthen innovation and resilience in protecting digital systems and societies.`,
    tags: ["#InternationalWomensDay", "#WomenInCybersecurity"]
  }
];
---

<Layout title="Insights | GrowUpward 2026">
  <main class="bg-[#0a0a0a] min-h-screen text-white pt-32 pb-20 relative overflow-hidden">
    
    <div class="absolute top-0 right-0 w-[600px] h-[500px] bg-cyan-500/5 rounded-full blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-1/4 left-0 w-[400px] h-[400px] bg-blue-600/5 rounded-full blur-[100px] pointer-events-none"></div>

    <Container>
      <div class="max-w-3xl mb-16 relative">
        <h1 class="text-5xl md:text-7xl font-black uppercase tracking-tighter mb-6">Latest <span class="text-gray-500">Insights</span></h1>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {insights.map((post) => (
          <article 
            class="group bg-white/[0.02] border border-white/10 rounded-[2.5rem] overflow-hidden backdrop-blur-sm hover:border-cyan-400/50 transition-all cursor-pointer flex flex-col shadow-xl"
            onclick={`openModal('${post.id}')`}
          >
            <div class="aspect-[16/10] overflow-hidden">
              <img src={post.image} class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700" />
            </div>
            <div class="p-8 flex flex-col flex-grow">
              <span class="text-gray-500 text-[10px] uppercase font-mono mb-3 block">{post.date}</span>
              <h2 class="text-xl font-bold mb-4 group-hover:text-cyan-400 transition-colors">{post.title}</h2>
              <p class="text-gray-400 text-sm mb-6 line-clamp-3 font-light leading-relaxed">{post.description}</p>
              <button class="mt-auto text-xs font-bold uppercase tracking-widest text-cyan-400 flex items-center gap-2 group-hover:gap-4 transition-all">
                Read Full Article →
              </button>
            </div>
          </article>
        ))}
      </div>

      <div class="mt-32 p-12 bg-white/[0.02] border border-white/10 rounded-[3rem] backdrop-blur-md text-center relative overflow-hidden group">
        <div class="absolute top-0 right-0 w-64 h-64 bg-cyan-400/10 rounded-full blur-[80px] -mr-32 -mt-32 group-hover:bg-cyan-400/20 transition-all"></div>
        <h3 class="text-3xl font-black uppercase mb-4">Never Miss an Update</h3>
        <p class="text-gray-400 max-w-xl mx-auto mb-8 font-light italic leading-relaxed">
          Subscribe to our intelligence briefing to stay ahead of emerging cyber threats and company announcements.
        </p>
        
        <form id="newsletter-form" class="flex flex-col sm:flex-row gap-4 max-w-md mx-auto relative z-10">
          <input 
            type="email" 
            name="email" 
            required 
            placeholder="Enter your email" 
            class="flex-grow bg-white/5 border border-white/10 rounded-2xl px-6 py-4 outline-none focus:border-cyan-400 transition" 
          />
          <button 
            type="submit" 
            id="sub-btn" 
            class="px-8 py-4 bg-cyan-400 text-black font-black uppercase tracking-widest text-xs rounded-2xl hover:bg-cyan-300 transition-all shadow-lg shadow-cyan-400/20 active:scale-95"
          >
            Subscribe
          </button>
        </form>
        <p id="sub-msg" class="mt-4 text-[10px] uppercase tracking-widest text-gray-500 hidden"></p>
      </div>

      <div id="article-modal" class="fixed inset-0 z-[100] hidden items-center justify-center p-4 sm:p-6 backdrop-blur-xl bg-black/80">
        <div class="bg-black/80 border border-white/10 w-full max-w-2xl max-h-[80vh] rounded-[2.5rem] overflow-y-auto p-8 sm:p-12 relative shadow-2xl">
          <button onclick="closeModal()" class="absolute top-6 right-6 text-gray-500 hover:text-white transition-colors text-2xl">&times;</button>
          <div id="modal-body">
             </div>
        </div>
      </div>

    </Container>
  </main>
</Layout>

<script is:inline define:vars={{ insights }}>
  window.openModal = function(id) {
    const post = insights.find(p => p.id === id);
    const modal = document.getElementById('article-modal');
    const body = document.getElementById('modal-body');
    
    if (post && modal && body) {
      body.innerHTML = `
        <span class="text-cyan-400 text-[10px] uppercase font-bold tracking-[0.2em] mb-4 block">${post.category}</span>
        <h2 class="text-3xl font-bold mb-6 leading-tight">${post.title}</h2>
        <div class="text-gray-400 leading-relaxed font-light space-y-4 text-base">
          ${post.fullContent}
        </div>
        <div class="mt-8 pt-8 border-t border-white/5 flex flex-wrap gap-4">
          ${post.tags.map(tag => `<span class="text-[10px] text-gray-600 font-mono bg-white/5 px-2 py-1 rounded">${tag}</span>`).join('')}
        </div>
      `;
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden'; 
    }
  }

  window.closeModal = function() {
    const modal = document.getElementById('article-modal');
    modal.classList.remove('flex');
    modal.classList.add('hidden');
    document.body.style.overflow = 'auto';
  }

  window.onclick = function(event) {
    const modal = document.getElementById('article-modal');
    if (event.target == modal) closeModal();
  }
</script>

<script is:inline define:vars={{ scriptURL: "https://script.google.com/macros/s/AKfycbxE9DnvLg2guRLeAE3jv74n2pq5SiJsFZU4pMQ19li8hS8zw_PK0WqpN78pVVJIn_bc/exec" }}>
  const subForm = document.getElementById('newsletter-form');
  const subBtn = document.getElementById('sub-btn');
  const subMsg = document.getElementById('sub-msg');

  if(subForm) {
    subForm.addEventListener('submit', e => {
      e.preventDefault();
      
      subBtn.disabled = true;
      subBtn.innerHTML = "WAIT...";
      subBtn.style.opacity = "0.7";

      const formData = new FormData(subForm);
      const params = new URLSearchParams();
      params.append('email', formData.get('email'));

      fetch(scriptURL, { 
        method: 'POST', 
        mode: 'no-cors', 
        cache: 'no-cache',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: params.toString()
      })
      .then(() => {
          subBtn.innerHTML = "SUBSCRIBED!";
          subBtn.classList.replace('bg-cyan-400', 'bg-emerald-500');
          subBtn.style.opacity = "1";
          subMsg.innerHTML = "SUCCESS! YOU ARE NOW SUBSCRIBED.";
          subMsg.classList.remove('hidden');
          subMsg.classList.add('text-emerald-400');
          subForm.reset();
      })
      .catch(error => {
          console.error('Error!', error.message);
          subBtn.disabled = false;
          subBtn.innerHTML = "TRY AGAIN";
          subBtn.style.opacity = "1";
      });
    });
  }
</script>
