---
import Layout from '../layouts/Layout.astro';
import Container from '../components/Container.astro';
---

<Layout title="Order Products | GrowUpward 2026">
  <main class="bg-[#0a0a0a] min-h-screen text-white pt-32 pb-20 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-cyan-500/5 rounded-full blur-[120px] pointer-events-none"></div>

    <Container>
      <div class="max-w-3xl mx-auto">
        <div class="mb-12 text-center">
            <h1 class="text-4xl md:text-5xl font-black uppercase tracking-tight mb-4">
                Product <span class="text-cyan-400">Inquiry</span>
            </h1>
            <p class="text-gray-400 font-light">เลือกโซลูชันที่คุณสนใจ และกรอกข้อมูลเพื่อให้ทีมงานติดต่อกลับเพื่อเสนอราคาพิเศษ</p>
        </div>

        <form class="space-y-10">
          <div class="space-y-6">
            <h2 class="text-xl font-bold uppercase tracking-widest text-cyan-400 border-l-4 border-cyan-400 pl-4">01. Select Products</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {["Anti-Scam Intelligence", "Cyber Resilience", "Human Risk Platform", "PDPA Compliance", "Industrial IoT & OT", "Secure Hardware"].map((product) => (
                <label class="relative flex items-center p-4 bg-white/[0.02] border border-white/10 rounded-2xl cursor-pointer hover:border-cyan-400/50 transition-all group">
                  <input type="checkbox" name="products" value={product} class="w-5 h-5 accent-cyan-400 bg-transparent border-white/20 rounded" />
                  <span class="ml-4 text-sm font-medium text-gray-300 group-hover:text-white">{product}</span>
                </label>
              ))}
            </div>
          </div>

          <div class="space-y-6">
            <h2 class="text-xl font-bold uppercase tracking-widest text-blue-400 border-l-4 border-blue-400 pl-4">02. Contact Information</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="space-y-2">
                <label class="text-[10px] uppercase tracking-widest font-bold text-gray-500">Full Name</label>
                <input type="text" placeholder="John Doe" class="w-full bg-white/[0.03] border border-white/10 rounded-xl px-4 py-3 outline-none focus:border-cyan-400 transition" required />
              </div>
              <div class="space-y-2">
                <label class="text-[10px] uppercase tracking-widest font-bold text-gray-500">Company Email</label>
                <input type="email" placeholder="john@company.com" class="w-full bg-white/[0.03] border border-white/10 rounded-xl px-4 py-3 outline-none focus:border-cyan-400 transition" required />
              </div>
              <div class="space-y-2">
                <label class="text-[10px] uppercase tracking-widest font-bold text-gray-500">Phone Number</label>
                <input type="tel" placeholder="+66 81..." class="w-full bg-white/[0.03] border border-white/10 rounded-xl px-4 py-3 outline-none focus:border-cyan-400 transition" required />
              </div>
              <div class="space-y-2">
                <label class="text-[10px] uppercase tracking-widest font-bold text-gray-500">Company Name</label>
                <input type="text" placeholder="Your Business Ltd." class="w-full bg-white/[0.03] border border-white/10 rounded-xl px-4 py-3 outline-none focus:border-cyan-400 transition" />
              </div>
            </div>
          </div>

          <div class="space-y-6">
            <h2 class="text-xl font-bold uppercase tracking-widest text-purple-400 border-l-4 border-purple-400 pl-4">03. Additional Remarks</h2>
            <div class="space-y-2">
              <label class="text-[10px] uppercase tracking-widest font-bold text-gray-500">How can we help you?</label>
              <textarea rows="4" placeholder="ระบุรายละเอียดเพิ่มเติม หรือคำถามที่ท่านต้องการทราบ..." class="w-full bg-white/[0.03] border border-white/10 rounded-2xl px-4 py-3 outline-none focus:border-cyan-400 transition resize-none"></textarea>
            </div>
          </div>

          <div class="pt-6">
            <button type="submit" class="w-full py-5 bg-cyan-400 hover:bg-cyan-300 text-black font-black uppercase tracking-[0.2em] text-sm rounded-2xl transition-all shadow-[0_0_20px_rgba(34,211,238,0.3)] hover:shadow-[0_0_30px_rgba(34,211,238,0.5)] active:scale-[0.98]">
              Send Inquiry Now
            </button>
            <p class="text-center text-[10px] text-gray-500 mt-4 uppercase tracking-widest">ทีมงานจะติดต่อกลับภายใน 24 ชั่วโมงในวันทำการ</p>
          </div>
        </form>
      </div>
    </Container>
  </main>
</Layout>
