---
import Layout from '../layouts/Layout.astro';
// (If there are other imports here originally, you can leave them!)
---

<Layout title="GrowUpward | Cyber-Resilience 2026">
  
  <section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden bg-[#0a0a0a]">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#1f2937_1px,transparent_1px),linear-gradient(to_bottom,#1f2937_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)] opacity-20"></div>

    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-cyan-600/20 blur-[120px] rounded-full pointer-events-none"></div>

    <div class="relative max-w-7xl mx-auto px-6 md:px-12 xl:px-6 flex flex-col items-center text-center">
      
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-cyan-500/30 bg-cyan-500/10 text-cyan-400 font-mono text-xs sm:text-sm mb-8 backdrop-blur-md">
        <span class="w-2 h-2 rounded-full bg-cyan-400 animate-pulse"></span>
        SYSTEM ONLINE // INITIATING PROTOCOL 2026
      </div>

      <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-white tracking-tight mb-6">
        Defend Bangkok from <br class="hidden sm:block" />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500">
          AI Scams & Deepfakes.
        </span>
      </h1>

      <p class="mt-4 text-gray-400 max-w-2xl text-lg sm:text-xl">
        The GrowUpward ecosystem begins here. Master digital literacy, PDPC compliance, and threat detection. Pre-order the foundational cybersecurity board game launching this April.
      </p>

      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a href="#preorder" class="relative group inline-flex items-center justify-center px-8 py-3.5 text-base font-bold text-black bg-cyan-400 rounded-full hover:bg-cyan-300 transition-all duration-300 shadow-[0_0_20px_rgba(34,211,238,0.4)] hover:shadow-[0_0_30px_rgba(34,211,238,0.6)]">
          Pre-Order the Game
        </a>
        <a href="#ecosystem" class="inline-flex items-center justify-center px-8 py-3.5 text-base font-medium text-white bg-white/5 border border-white/10 rounded-full hover:bg-white/10 backdrop-blur-md transition-all duration-300 font-mono">
          Explore Ecosystem
        </a>
      </div>

      <div class="mt-16 relative w-full max-w-4xl mx-auto">
        <div class="absolute bottom-0 inset-x-0 h-1/3 bg-gradient-to-t from-[#0a0a0a] to-transparent z-10"></div>
        
        <div class="relative z-0 w-full aspect-[16/9] bg-white/5 border border-white/10 rounded-3xl flex items-center justify-center backdrop-blur-sm shadow-[0_0_50px_rgba(34,211,238,0.1)]">
          <span class="text-gray-500 font-mono">[ UPLOAD TRANSPARENT BOARD GAME 3D RENDER HERE ]</span>
        </div>
      </div>

    </div>
  </section>
  </Layout>
