---
import Layout from '../layouts/Layout.astro';
import Container from '../components/Container.astro';
---

<Layout title="GrowUpward | Cyber-Resilience 2026">
  
  <section class="relative pt-24 pb-20 lg:pt-48 lg:pb-32 overflow-hidden bg-[#0a0a0a]">
    
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#1f2937_1px,transparent_1px),linear-gradient(to_bottom,#1f2937_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)] opacity-20"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-cyan-600/20 blur-[120px] rounded-full pointer-events-none"></div>

    <Container>
      <div class="relative flex flex-col items-center text-center">
        
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-cyan-500/30 bg-cyan-500/10 text-cyan-400 font-mono text-[10px] sm:text-sm mb-8 backdrop-blur-md">
          <span class="w-2 h-2 rounded-full bg-cyan-400 animate-pulse"></span>
          PROTECT YOUR DATA AND ASSETS 2026
        </div>

        <h1 class="text-4xl md:text-6xl lg:text-7xl font-black uppercase text-white tracking-tighter mb-6 leading-[0.9]">
          Defend Your Ecosystem from <br class="hidden sm:block" />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500">
            AI Threats & Deepfakes.
          </span>
        </h1>

        <p class="mt-4 text-gray-400 max-w-2xl text-base sm:text-xl font-light leading-relaxed">
          GrowUpward begins here—advancing digital literacy, PDPC compliance, and threat detection, bridging social impact with technology-driven innovation.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row justify-center gap-4 w-full max-w-sm sm:max-w-none">
  
  <a href="/order" class="relative group inline-flex items-center justify-center px-10 py-4 text-sm font-black uppercase tracking-widest text-black bg-cyan-400 rounded-2xl hover:bg-cyan-300 transition-all duration-300 shadow-[0_0_20px_rgba(34,211,238,0.4)] hover:shadow-[0_0_40px_rgba(34,211,238,0.6)] active:scale-95">
    Order Product
  </a>
  
  <a href="/about" class="inline-flex items-center justify-center px-10 py-4 text-sm font-bold uppercase tracking-widest text-white bg-white/5 border border-white/10 rounded-2xl hover:bg-white/10 backdrop-blur-md transition-all duration-300 active:scale-95">
    Explore Ecosystem
  </a>

</div>

        <div class="mt-20 relative w-full max-w-5xl mx-auto group">
          <div class="absolute -inset-1 bg-gradient-to-r from-cyan-500 to-blue-600 rounded-[2.5rem] blur opacity-20 group-hover:opacity-40 transition duration-1000"></div>
          
          <div class="relative z-0 w-full aspect-video bg-black border border-white/10 rounded-[2rem] overflow-hidden shadow-2xl">
            <video 
              id="heroVideo"
              autoplay 
              loop 
              muted 
              playsinline 
              webkit-playsinline
              preload="auto"
              poster="/boardgame.png" 
              class="w-full h-full object-cover opacity-80"
            >
              <source src="/hero-video.mp4" type="video/mp4" />
            </video>
            
            <div class="absolute inset-0 bg-gradient-to-t from-[#0a0a0a] via-transparent to-transparent"></div>
          </div>
        </div>

      </div>
    </Container>
  </section>

</Layout>

<script is:inline>
  // iOS Autoplay Fix (คงเดิมเพราะสำคัญมาก)
  document.addEventListener('DOMContentLoaded', () => {
    const video = document.getElementById('heroVideo');
    if (video) {
      let playPromise = video.play();
      if (playPromise !== undefined) {
        playPromise.catch(() => {
          window.addEventListener('touchstart', () => {
            video.play();
          }, { once: true });
        });
      }
    }
  });
</script>

<style>
  /* ซ่อน Media Controls บน iOS */
  video::-webkit-media-controls-start-playback-button,
  video::-webkit-media-controls {
    display: none !important;
    -webkit-appearance: none;
  }
</style>
