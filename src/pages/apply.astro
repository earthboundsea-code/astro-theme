---
import Layout from '../layouts/Layout.astro';
import Container from '../components/Container.astro';
---

<Layout title="Apply Now | GrowUpward 2026">
  <main class="bg-[#0a0a0a] min-h-screen text-white pt-32 pb-20 relative overflow-hidden">
    
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-cyan-500/10 rounded-full blur-[120px] pointer-events-none"></div>

    <Container>
        <div class="max-w-7xl mx-auto flex flex-col lg:flex-row gap-16 lg:gap-24 items-start">
            
            <div class="w-full lg:w-1/2 flex flex-col pt-4">
                <a href="/join" class="text-gray-500 hover:text-white text-xs uppercase tracking-widest transition-colors mb-10 inline-block w-fit">
                    ← Back to Careers
                </a>

                <h1 id="jd-title" class="text-3xl md:text-5xl font-black uppercase tracking-tight text-white mb-6 leading-tight">
                    General Application
                </h1>
                
                <div class="flex items-center gap-3 mb-10">
                    <span id="jd-type" class="px-4 py-1.5 bg-white/10 text-gray-300 text-[10px] uppercase tracking-widest rounded-full font-bold">...</span>
                    <span id="jd-location" class="px-4 py-1.5 bg-white/10 text-gray-300 text-[10px] uppercase tracking-widest rounded-full font-bold">...</span>
                </div>

                <div id="jd-content" class="text-gray-400 text-sm md:text-base leading-relaxed space-y-6">
                    <p>กำลังโหลดรายละเอียดงาน...</p>
                </div>
            </div>

            <div class="w-full lg:w-1/2 bg-white/[0.02] border border-white/10 p-8 md:p-12 rounded-[2rem] shadow-2xl relative z-10 backdrop-blur-sm mt-8 lg:mt-0">
                
                <div class="text-center mb-10">
                    <h2 class="text-2xl font-black uppercase tracking-widest text-white mb-2">Submit Application</h2>
                    <p id="form-role-display" class="text-cyan-400 text-xs tracking-widest uppercase font-bold">
                        Applying for: General Application
                    </p>
                </div>

                <form id="applicationForm" action="https://forminit.com/f/fjyf1064yed" method="POST" enctype="multipart/form-data" class="space-y-6">
                    <input type="hidden" name="applied_position" id="hidden-role" value="General Application" />

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="text-[10px] text-gray-400 uppercase tracking-widest ml-2">First Name (ชื่อ)</label>
                            <input type="text" name="first_name" required class="w-full bg-[#0a0a0a] border border-white/10 rounded-xl px-4 py-4 text-white focus:border-cyan-400 outline-none transition text-sm shadow-inner" />
                        </div>
                        <div class="space-y-2">
                            <label class="text-[10px] text-gray-400 uppercase tracking-widest ml-2">Last Name (นามสกุล)</label>
                            <input type="text" name="last_name" required class="w-full bg-[#0a0a0a] border border-white/10 rounded-xl px-4 py-4 text-white focus:border-cyan-400 outline-none transition text-sm shadow-inner" />
                        </div>
                    </div>

                    <div class="space-y-2">
                        <label class="text-[10px] text-gray-400 uppercase tracking-widest ml-2">Email Address (อีเมล)</label>
                        <input type="email" name="email" required class="w-full bg-[#0a0a0a] border border-white/10 rounded-xl px-4 py-4 text-white focus:border-cyan-400 outline-none transition text-sm shadow-inner" />
                    </div>

                    <div class="space-y-2">
                        <label class="text-[10px] text-gray-400 uppercase tracking-widest ml-2">Phone Number (เบอร์ติดต่อ)</label>
                        <input type="tel" name="phone" required class="w-full bg-[#0a0a0a] border border-white/10 rounded-xl px-4 py-4 text-white focus:border-cyan-400 outline-none transition text-sm shadow-inner" />
                    </div>

                    <div class="space-y-2">
                        <label class="text-[10px] text-gray-400 uppercase tracking-widest ml-2">Upload CV (PDF Only)</label>
                        <input type="file" name="file" accept=".pdf" required class="block w-full text-sm text-gray-400 file:mr-4 file:py-3 file:px-6 file:rounded-xl file:border-0 file:text-xs file:font-bold file:bg-cyan-400 file:text-black hover:file:bg-white cursor-pointer transition-all border border-white/10 rounded-xl bg-[#0a0a0a]" />
                    </div>

                    <button type="submit" id="submitBtn" class="w-full py-4 mt-8 bg-cyan-400 hover:bg-white text-black font-black rounded-xl transition-all duration-300 uppercase tracking-widest text-sm shadow-[0_0_20px_rgba(34,211,238,0.2)] hover:shadow-[0_0_30px_rgba(255,255,255,0.4)]">
                        Submit Application
                    </button>
                </form>

            </div>
        </div>
    </Container>
  </main>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
        // ส่วนจัดการข้อมูลรายละเอียดงาน
        const params = new URLSearchParams(window.location.search);
        const role = params.get('role');

        const jdTitle = document.getElementById('jd-title');
        const jdType = document.getElementById('jd-type');
        const jdLocation = document.getElementById('jd-location');
        const jdContent = document.getElementById('jd-content');
        const formRoleDisplay = document.getElementById('form-role-display');
        const hiddenRoleInput = document.getElementById('hidden-role');

        const jobData = {
            "Cybersecurity & PDPA Consultant": {
                type: "Full-time", location: "Bangkok (Hybrid)",
                desc: "<h3 class='text-white font-bold uppercase tracking-widest text-xs mt-8 mb-4'>หน้าที่ความรับผิดชอบ</h3><ul class='list-disc pl-5 space-y-2 text-gray-400'><li>ให้คำปรึกษาด้าน Cybersecurity และ PDPA แก่ลูกค้า B2B ตรวจประเมิน (Audit) ให้เป็นไปตามมาตรฐานสากล</li><li>พัฒนาและวางระบบ PDPA รวมถึงจัดทำ Data Mapping และร่างนโยบายความเป็นส่วนตัว</li><li>ออกแบบและนำนโยบายความปลอดภัยไซเบอร์ไปปฏิบัติใช้</li></ul>"
            },
            "B2B Tech Solutions Sales": {
                type: "Full-time (Junior)", location: "Bangkok (Hybrid)",
                desc: "<h3 class='text-white font-bold uppercase tracking-widest text-xs mt-8 mb-4'>หน้าที่ความรับผิดชอบ</h3><ul class='list-disc pl-5 space-y-2 text-gray-400'><li>ค้นหาและขยายฐานลูกค้าองค์กร (B2B) และวางแผนกลยุทธ์การขาย</li><li>เข้าพบลูกค้า นำเสนอ และสาธิตโซลูชัน (Product Demo)</li></ul>"
            },
            "Lead AI / Full-Stack Engineer": {
                type: "Junior / Fast-track Lead", location: "Bangkok (Hybrid)",
                desc: "<h3 class='text-white font-bold uppercase tracking-widest text-xs mt-8 mb-4'>หน้าที่ความรับผิดชอบ</h3><ul class='list-disc pl-5 space-y-2 text-gray-400'><li>ออกแบบและพัฒนาโซลูชัน AI และระบบ Full-Stack แบบ End-to-End</li></ul>"
            },
            "Penetration Tester / Ethical Hacker": {
                type: "Full-time", location: "Bangkok (Hybrid)",
                desc: "<h3 class='text-white font-bold uppercase tracking-widest text-xs mt-8 mb-4'>หน้าที่ความรับผิดชอบ</h3><ul class='list-disc pl-5 space-y-2 text-gray-400'><li>ทดสอบเจาะระบบ Web, Network และ Application เพื่อค้นหาจุดอ่อน</li></ul>"
            },
            "AI / Machine Learning Intern": {
                type: "Internship (3 Months)", location: "Hybrid / Remote",
                desc: "<h3 class='text-white font-bold uppercase tracking-widest text-xs mt-8 mb-4'>หน้าที่ความรับผิดชอบ</h3><ul class='list-disc pl-5 space-y-2 text-gray-400'><li>สร้างและพัฒนาโมเดลตรวจจับกลโกงจาก Text, Phone และ Image</li></ul>"
            },
            "Cybersecurity Analyst Intern": {
                type: "Internship (3 Months)", location: "Hybrid / Remote",
                desc: "<h3 class='text-white font-bold uppercase tracking-widest text-xs mt-8 mb-4'>หน้าที่ความรับผิดชอบ</h3><ul class='list-disc pl-5 space-y-2 text-gray-400'><li>วิเคราะห์รูปแบบการหลอกลวงและระบุระดับความเสี่ยงภัยคุกคาม</li></ul>"
            },
            "Threat Intelligence Intern": {
                type: "Internship (3 Months)", location: "Hybrid / Remote",
                desc: "<h3 class='text-white font-bold uppercase tracking-widest text-xs mt-8 mb-4'>หน้าที่ความรับผิดชอบ</h3><ul class='list-disc pl-5 space-y-2 text-gray-400'><li>วิจัยและติดตามภัยคุกคามใหม่ๆ (Scams/Phishing)</li></ul>"
            },
            "UX/UI Design Intern": {
                type: "Internship (3 Months)", location: "Hybrid / Remote",
                desc: "<h3 class='text-white font-bold uppercase tracking-widest text-xs mt-8 mb-4'>หน้าที่ความรับผิดชอบ</h3><ul class='list-disc pl-5 space-y-2 text-gray-400'><li>ออกแบบ UX/UI แพลตฟอร์มความปลอดภัยให้ใช้งานง่าย</li></ul>"
            },
            "Event Planning Intern": {
                type: "Internship (3 Months)", location: "Hybrid / Remote",
                desc: "<h3 class='text-white font-bold uppercase tracking-widest text-xs mt-8 mb-4'>หน้าที่ความรับผิดชอบ</h3><ul class='list-disc pl-5 space-y-2 text-gray-400'><li>ร่วมออกแบบแนวคิดกิจกรรม (Workshop, Product Launch)</li></ul>"
            },
            "Marketing Intern": {
                type: "Internship (3 Months)", location: "Hybrid / Remote",
                desc: "<h3 class='text-white font-bold uppercase tracking-widest text-xs mt-8 mb-4'>หน้าที่ความรับผิดชอบ</h3><ul class='list-disc pl-5 space-y-2 text-gray-400'><li>สร้างสรรค์ Content และวางกลยุทธ์ Social Media</li></ul>"
            }
        };

        if (role) {
            const data = jobData[role];
            if (data) {
                jdTitle.textContent = role;
                formRoleDisplay.textContent = `Applying for: ${role}`;
                hiddenRoleInput.value = role;
                jdType.textContent = data.type;
                jdLocation.textContent = data.location;
                jdContent.innerHTML = data.desc;
            }
        }

        // ส่วนของการส่งฟอร์ม (Fetch API + ป้องกันการคลิกซ้ำ)
        const form = document.getElementById('applicationForm');
        const submitBtn = document.getElementById('submitBtn');

        if (form) {
            form.addEventListener('submit', async (e) => {
                e.preventDefault(); // ป้องกันการเปลี่ยนหน้าแบบปกติ
                
                const formData = new FormData(form);
                
                // เปลี่ยนสถานะปุ่ม
                submitBtn.textContent = 'Sending Application...';
                submitBtn.disabled = true;
                submitBtn.style.opacity = '0.5';
                submitBtn.style.cursor = 'not-allowed';

                try {
                    const response = await fetch(form.action, {
                        method: 'POST',
                        body: formData,
                        headers: {
                            'Accept': 'application/json'
                        }
                    });

                    if (response.ok) {
                        // ส่งสำเร็จ วิ่งไปหน้า Thank you ของ Forminit
                        window.location.href = 'https://forminit.com/thank-you'; 
                    } else {
                        const result = await response.json();
                        alert('Error: ' + (result.message || 'Something went wrong.'));
                        // คืนสถานะปุ่ม
                        submitBtn.disabled = false;
                        submitBtn.textContent = 'Submit Application';
                        submitBtn.style.opacity = '1';
                        submitBtn.style.cursor = 'pointer';
                    }
                } catch (error) {
                    alert('Failed to send application. Please try again.');
                    // คืนสถานะปุ่ม
                    submitBtn.disabled = false;
                    submitBtn.textContent = 'Submit Application';
                    submitBtn.style.opacity = '1';
                    submitBtn.style.cursor = 'pointer';
                }
            });
        }
    });
  </script>
</Layout>
