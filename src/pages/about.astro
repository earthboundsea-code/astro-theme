---
import Layout from '../layouts/Layout.astro';
import Container from '../components/Container.astro';
---

<Layout title="About Us | GrowUpward 2026">
  <main class="bg-[#0a0a0a] min-h-screen text-white pt-32 pb-20 relative overflow-hidden">
    
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-cyan-500/5 rounded-full blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-1/4 left-0 w-[400px] h-[400px] bg-blue-600/5 rounded-full blur-[100px] pointer-events-none"></div>

    <Container>
      <div class="max-w-4xl mx-auto text-center pt-12 md:pt-20 mb-24">
        <span class="px-4 py-1.5 bg-cyan-400/10 text-cyan-400 text-[10px] uppercase tracking-[0.2em] rounded-full font-bold border border-cyan-400/20 mb-6 inline-block">
            Our Purpose
        </span>
        <h1 class="text-4xl md:text-7xl font-black uppercase tracking-tighter leading-[0.9] mb-8">
            Bridging <span class="text-cyan-400">Security</span> <br/>with Human Impact.
        </h1>
        <p class="text-gray-400 text-lg md:text-xl leading-relaxed font-light">
            GrowUpward was founded in 2026 to confront the greatest challenges of our era: <br class="hidden md:block"/> 
            <span class="text-white font-medium">The rapid advancement of AI and threats more complex than human intuition alone can handle.</span>
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-32">
        
        <div class="p-8 bg-white/[0.02] border border-white/10 rounded-[2.5rem] hover:border-cyan-400/50 transition-all duration-500 group">
          <div class="w-12 h-12 bg-cyan-400 text-black flex items-center justify-center rounded-2xl mb-6 font-bold group-hover:scale-110 transition-transform">01</div>
          <h3 class="text-xl font-bold uppercase tracking-widest mb-4 text-cyan-400">Anti-Scam Intelligence</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            Our MVP ecosystem features real-time <span class="text-white font-medium">Scam Checkers</span>, advanced <span class="text-white font-medium">Deepfake Detection</span>, and <span class="text-white font-medium">Face Misuse Monitoring</span> to intercept fraud at its source.
          </p>
        </div>

        <div class="p-8 bg-white/[0.02] border border-white/10 rounded-[2.5rem] hover:border-blue-500/50 transition-all duration-500 group">
          <div class="w-12 h-12 bg-blue-500 text-white flex items-center justify-center rounded-2xl mb-6 font-bold group-hover:scale-110 transition-transform">02</div>
          <h3 class="text-xl font-bold uppercase tracking-widest mb-4 text-blue-400">Cyber Resilience</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            Strengthening your core through professional <span class="text-white font-medium">Penetration Testing (Pentest)</span> and rapid <span class="text-white font-medium">Incident Response (IR)</span> to ensure business continuity.
          </p>
        </div>

        <div class="p-8 bg-white/[0.02] border border-white/10 rounded-[2.5rem] hover:border-purple-500/50 transition-all duration-500 group">
          <div class="w-12 h-12 bg-purple-500 text-white flex items-center justify-center rounded-2xl mb-6 font-bold group-hover:scale-110 transition-transform">03</div>
          <h3 class="text-xl font-bold uppercase tracking-widest mb-4 text-purple-400">Human Risk Platform</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            Eliminating the weakest link with <span class="text-white font-medium">Phishing Simulations</span>, Digital Literacy training, and a comprehensive <span class="text-white font-medium">Human Risk Score Dashboard</span>.
          </p>
        </div>

        <div class="p-8 bg-white/[0.02] border border-white/10 rounded-[2.5rem] hover:border-emerald-500/50 transition-all duration-500 group">
          <div class="w-12 h-12 bg-emerald-500 text-white flex items-center justify-center rounded-2xl mb-6 font-bold group-hover:scale-110 transition-transform">04</div>
          <h3 class="text-xl font-bold uppercase tracking-widest mb-4 text-emerald-400">PDPA Compliance</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            Comprehensive <span class="text-white font-medium">PDPA Bundle</span> services including data mapping, privacy policy drafting, and legal tech consulting.
          </p>
        </div>

        <div class="p-8 bg-white/[0.02] border border-white/10 rounded-[2.5rem] hover:border-orange-500/50 transition-all duration-500 group">
          <div class="w-12 h-12 bg-orange-500 text-white flex items-center justify-center rounded-2xl mb-6 font-bold group-hover:scale-110 transition-transform">05</div>
          <h3 class="text-xl font-bold uppercase tracking-widest mb-4 text-orange-400">Industrial IoT & OT</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            Securing the production line with <span class="text-white font-medium">Factory Device Security</span>, real-time <span class="text-white font-medium">Network Monitoring (OT)</span>, and technical Risk Assessments.
          </p>
        </div>

        <div class="p-8 bg-white/[0.02] border border-white/10 rounded-[2.5rem] hover:border-amber-500/50 transition-all duration-500 group">
          <div class="w-12 h-12 bg-amber-500 text-black flex items-center justify-center rounded-2xl mb-6 font-bold group-hover:scale-110 transition-transform">06</div>
          <h3 class="text-xl font-bold uppercase tracking-widest mb-4 text-amber-400">Secure Hardware</h3>
          <p class="text-gray-400 text-sm leading-relaxed mb-6">
            The definitive standard for **professional environments**. High-performance hardware specifically engineered to secure **corporate assets**, ensure **executive privacy**, and protect **confidential workspaces**.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="px-2 py-1 bg-white/5 border border-white/10 rounded-lg text-[9px] text-gray-300 uppercase font-bold tracking-wider">Security Keys</span>
            <span class="px-2 py-1 bg-white/5 border border-white/10 rounded-lg text-[9px] text-gray-300 uppercase font-bold tracking-wider">Data Diodes</span>
            <span class="px-2 py-1 bg-white/5 border border-white/10 rounded-lg text-[9px] text-gray-300 uppercase font-bold tracking-wider">Faraday</span>
            <span class="px-2 py-1 bg-white/5 border border-white/10 rounded-lg text-[9px] text-white uppercase font-bold tracking-wider">Data Blockers</span>
            <span class="px-2 py-1 bg-white/5 border border-white/10 rounded-lg text-[9px] text-gray-300 uppercase font-bold tracking-wider">Mic-Locks</span>
            <span class="px-2 py-1 bg-white/5 border border-white/10 rounded-lg text-[9px] text-gray-300 uppercase font-bold tracking-wider">VPN Routers</span>
            <span class="px-2 py-1 bg-white/5 border border-white/10 rounded-lg text-[9px] text-white uppercase font-bold tracking-wider">AI Hubs</span>
          </div>
        </div>

      </div>

      <div class="flex flex-col lg:flex-row items-center gap-16 lg:gap-32">
        <div class="w-full lg:w-1/2 relative">
            <div class="aspect-square bg-gradient-to-tr from-cyan-950 to-[#0a0a0a] border border-white/10 rounded-[3rem] overflow-hidden flex items-center justify-center group">
                <div class="absolute inset-0 bg-cyan-500/10 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                <img src="/anti-scam-art.png" alt="Vision Art" class="w-4/5 h-auto grayscale group-hover:grayscale-0 transition-all duration-700" />
            </div>
            <div class="absolute -bottom-6 -right-6 bg-white text-black p-8 rounded-[2rem] hidden md:block shadow-2xl">
                <p class="text-4xl font-black italic">"Innovation for All"</p>
            </div>
        </div>

        <div class="w-full lg:w-1/2 space-y-8">
            <h2 class="text-3xl font-black uppercase tracking-tight">
                Not Just Another Tech Startup. <br/> <span class="text-gray-500">We Build Resilience.</span>
            </h2>
            <div class="space-y-6 text-gray-400 font-light leading-relaxed text-sm md:text-base">
                <p>
                    At <span class="text-white font-bold tracking-widest uppercase">GrowUpward</span>, we believe that great technology should work silently in the background, yet speak loudly through its social impact.
                </p>
                <p>
                    Our mission is to bridge cutting-edge innovation with human understanding. We don't just build software; we are building an <span class="text-white font-medium italic">"Ecosystem of Trust"</span> where everyone can advance safely and grow upward with confidence.
                </p>
            </div>
            
            <div class="pt-8 flex flex-wrap gap-4">
                <a href="/join" class="px-8 py-4 bg-white text-black font-black uppercase tracking-widest text-xs rounded-2xl hover:bg-cyan-400 transition-all">
                    Join Our Mission
                </a>
                <div class="flex items-center gap-4 px-6 py-4 border border-white/10 rounded-2xl">
                    <span class="flex h-2 w-2 rounded-full bg-green-500 animate-pulse"></span>
                    <span class="text-[10px] uppercase tracking-widest font-bold">Scaling Phase 2026</span>
                </div>
            </div>
        </div>
      </div>
    </Container>
  </main>
</Layout>
