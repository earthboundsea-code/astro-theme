---
import Layout from '../layouts/Layout.astro';
import Container from '../components/Container.astro';

const jobs = [
    { title: "Cyber Security Instructor", city: "Bangkok", type: "Full-time", hot: true, desc: "ดูแลและพัฒนาหลักสูตรการสอนด้านความปลอดภัยไซเบอร์..." },
    { title: "AI/Full-Stack Developer", city: "Remote / BKK", type: "Full-time", hot: true, desc: "พัฒนา Platform และระบบ Simulation สำหรับการฝึกฝน..." },
    { title: "Content Creator (Cyber Literacy)", city: "Bangkok", type: "Full-time", hot: false, desc: "สร้างสรรค์สื่อดิจิทัลเพื่อสร้างความตระหนักรู้ด้านภัยไซเบอร์..." },
    { title: "Internship (Any Roles)", city: "Bangkok", type: "Intern", hot: false, desc: "เปิดรับนักศึกษาฝึกงานที่พร้อมเรียนรู้เทคโนโลยีใหม่ๆ..." },
];
---

<Layout title="Careers | GrowUpward 2026">
  <main class="bg-[#0a0a0a] min-h-screen text-white font-sans">
    
    <section class="relative min-h-[80vh] flex flex-col items-center justify-center overflow-hidden pt-20">
        <div class="absolute inset-0 z-0">
            <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&q=80" class="w-full h-full object-cover opacity-20" alt="Teamwork" />
            <div class="absolute inset-0 bg-gradient-to-b from-[#0a0a0a] via-transparent to-[#0a0a0a]"></div>
        </div>
        
        <div class="relative z-10 max-w-4xl mx-auto text-center px-4 mt-10">
            <h1 class="text-7xl md:text-[120px] font-black mb-4 tracking-tighter leading-none uppercase italic">
                JOIN <br/> 
                <span class="text-cyan-400 not-italic">GROWUPWARD</span>
            </h1>
            <p class="text-lg md:text-xl text-gray-400 mb-10 font-light tracking-widest uppercase">
                Join us and make something people love
            </p>
            
            <div class="max-w-xl mx-auto relative group">
                <div class="absolute -inset-1 bg-gradient-to-r from-cyan-400 to-blue-500 rounded-full blur opacity-25 group-hover:opacity-50 transition duration-1000"></div>
                <input type="text" placeholder="ค้นหาตำแหน่งงาน..." class="relative w-full bg-black/50 border border-white/10 backdrop-blur-xl rounded-full py-4 px-8 outline-none focus:border-cyan-400 transition text-white" />
                <button class="absolute right-5 top-1/2 -translate-y-1/2 text-gray-400 hover:text-cyan-400 transition">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                </button>
            </div>
        </div>

        <div class="relative z-10 mt-24 pb-20 w-full">
            <Container>
                <div class="flex flex-col items-center">
                    <h2 class="text-xs font-black uppercase tracking-[0.5em] text-cyan-400/60 mb-12">Why GrowUpward</h2>
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12 text-center w-full">
                        <div class="flex flex-col items-center gap-3">
                            <span class="text-3xl">💡</span>
                            <h3 class="font-bold text-sm uppercase tracking-wider text-white">Creativity First</h3>
                        </div>
                        <div class="flex flex-col items-center gap-3">
                            <span class="text-3xl">🌍</span>
                            <h3 class="font-bold text-sm uppercase tracking-wider text-white">Global Network</h3>
                        </div>
                        <div class="flex flex-col items-center gap-3">
                            <span class="text-3xl">📈</span>
                            <h3 class="font-bold text-sm uppercase tracking-wider text-white">Growth Mindset</h3>
                        </div>
                        <div class="flex flex-col items-center gap-3">
                            <span class="text-3xl">😊</span>
                            <h3 class="font-bold text-sm uppercase tracking-wider text-white">Work as Play</h3>
                        </div>
                    </div>
                </div>
            </Container>
        </div>
    </section>

    <section class="py-24 bg-white/[0.01] border-t border-white/5">
        <Container>
            <div class="max-w-4xl mx-auto">
                <div class="flex justify-between items-center mb-12">
                    <h2 class="text-3xl font-bold tracking-tight">Open Positions</h2>
                    <div class="text-xs text-gray-500 uppercase tracking-widest">{jobs.length} roles available</div>
                </div>

                <div class="space-y-4">
                    {jobs.map((job) => (
                        <div class="p-6 md:p-8 bg-white/5 border border-white/10 rounded-2xl hover:border-cyan-400/50 transition-all duration-500 group relative overflow-hidden">
                            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 relative z-10">
                                <div>
                                    <h4 class="text-xl font-bold flex items-center gap-3 text-white">
                                        {job.title}
                                        {job.hot && <span class="text-[9px] bg-cyan-400 text-black px-2 py-0.5 rounded-full font-black uppercase tracking-tighter">Hot</span>}
                                    </h4>
                                    <div class="flex gap-4 mt-2 text-xs text-gray-500 font-medium uppercase">
                                        <span>📍 {job.city}</span>
                                        <span>💼 {job.type}</span>
                                    </div>
                                </div>
                                <a href="#apply" class="w-full md:w-auto text-center px-8 py-3 bg-white text-black rounded-full font-bold text-sm hover:bg-cyan-400 transition-colors">
                                    Apply
                                </a>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </Container>
    </section>

    <section id="apply" class="py-32 bg-[#0a0a0a]">
        <Container>
            <div class="max-w-2xl mx-auto bg-white/5 border border-white/10 p-10 md:p-16 rounded-[2.5rem] shadow-2xl">
                <h3 class="text-2xl font-bold mb-10 text-center uppercase tracking-widest">Application Form</h3>
                <form action="https://formspree.io/f/YOUR_ID" method="POST" enctype="multipart/form-data" class="space-y-6">
                    <input type="text" name="name" required placeholder="Full Name" class="w-full bg-black/50 border border-white/10 rounded-2xl px-6 py-4 text-white focus:border-cyan-400 outline-none transition" />
                    <input type="email" name="email" required placeholder="Email Address" class="w-full bg-black/50 border border-white/10 rounded-2xl px-6 py-4 text-white focus:border-cyan-400 outline-none transition" />
                    <select name="position" class="w-full bg-black/50 border border-white/10 rounded-2xl px-6 py-4 text-white focus:border-cyan-400 outline-none appearance-none cursor-pointer uppercase text-xs font-bold tracking-widest">
                        {jobs.map(job => <option value={job.title}>{job.title}</option>)}
                    </select>
                    <div class="border-2 border-dashed border-white/10 rounded-2xl p-8 text-center hover:border-cyan-400/50 transition cursor-pointer relative">
                        <input type="file" name="cv" accept=".pdf" required class="absolute inset-0 opacity-0 cursor-pointer" />
                        <span class="text-sm text-gray-400">Upload CV (PDF)</span>
                    </div>
                    <textarea name="message" rows="4" placeholder="Tell us about yourself..." class="w-full bg-black/50 border border-white/10 rounded-2xl px-6 py-4 text-white focus:border-cyan-400 outline-none transition resize-none"></textarea>
                    <button type="submit" class="w-full py-5 bg-cyan-400 hover:bg-white text-black font-black rounded-full transition-all duration-500 uppercase tracking-[0.2em] text-sm">
                        Send Application
                    </button>
                </form>
            </div>
        </Container>
    </section>

  </main>
</Layout>
