---
import Layout from '../layouts/Layout.astro';
import Container from '../components/Container.astro';

const jobs = [
    { title: "Cyber Security Instructor", city: "Bangkok", type: "Full-time", hot: true, desc: "ดูแลและพัฒนาหลักสูตรการสอนด้านความปลอดภัยไซเบอร์..." },
    { title: "AI/Full-Stack Developer", city: "Remote / BKK", type: "Full-time", hot: true, desc: "พัฒนา Platform และระบบ Simulation สำหรับการฝึกฝน..." },
    { title: "Content Creator (Cyber Literacy)", city: "Bangkok", type: "Full-time", hot: false, desc: "สร้างสรรค์สื่อดิจิทัลเพื่อสร้างความตระหนักรู้ด้านภัยไซเบอร์..." },
    { title: "Internship (Any Roles)", city: "Bangkok", type: "Intern", hot: false, desc: "เปิดรับนักศึกษาฝึกงานที่พร้อมเรียนรู้เทคโนโลยีใหม่ๆ..." },
];
---

<Layout title="Careers | GrowUpward 2026">
  <main class="bg-[#0a0a0a] min-h-screen text-white">
    
    <section class="relative pt-40 pb-20 flex flex-col items-center justify-center overflow-hidden">
        <div class="absolute inset-0 z-0">
            <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&q=80" class="w-full h-full object-cover opacity-20" alt="Teamwork" />
            <div class="absolute inset-0 bg-gradient-to-b from-[#0a0a0a] via-transparent to-[#0a0a0a]"></div>
        </div>
        
        <div class="relative z-10 max-w-4xl mx-auto text-center px-4">
            <h1 class="text-4xl md:text-6xl font-black mb-2 tracking-tighter leading-none uppercase italic text-white/90">
                JOIN
            </h1>
            <h2 class="text-6xl md:text-8xl font-black mb-8 tracking-tighter leading-none uppercase text-cyan-400">
                GROWUPWARD
            </h2>
            
            <p class="text-base md:text-lg text-gray-400 mb-10 tracking-[0.2em] uppercase font-light">
                Join us to protect a fundamental human necessity
            </p>
            
            <div class="max-w-md mx-auto relative group">
                <input type="text" placeholder="ค้นหาตำแหน่งงาน..." class="w-full bg-white/5 border border-white/10 backdrop-blur-md rounded-full py-3 px-6 outline-none focus:border-cyan-400/50 transition text-sm" />
                <button class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 hover:text-cyan-400 transition">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                </button>
            </div>
        </div>
    </section>

    <section class="pb-32">
        <Container>
            <div class="flex flex-col items-center">
                <h3 class="text-[10px] font-black uppercase tracking-[0.8em] text-white/30 mb-16 italic">Why GrowUpward</h3>
                
                <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-16 text-center w-full max-w-5xl">
                    <div class="space-y-4 group">
                        <div class="text-4xl filter grayscale group-hover:grayscale-0 transition duration-500">💡</div>
                        <h4 class="font-bold text-xs uppercase tracking-widest text-white/80">Creativity First</h4>
                    </div>
                    <div class="space-y-4 group">
                        <div class="text-4xl filter grayscale group-hover:grayscale-0 transition duration-500">🌍</div>
                        <h4 class="font-bold text-xs uppercase tracking-widest text-white/80">Global Network</h4>
                    </div>
                    <div class="space-y-4 group">
                        <div class="text-4xl filter grayscale group-hover:grayscale-0 transition duration-500">📈</div>
                        <h4 class="font-bold text-xs uppercase tracking-widest text-white/80">Growth Mindset</h4>
                    </div>
                    <div class="space-y-4 group">
                        <div class="text-4xl filter grayscale group-hover:grayscale-0 transition duration-500">😊</div>
                        <h4 class="font-bold text-xs uppercase tracking-widest text-white/80">Work as Play</h4>
                    </div>
                </div>
            </div>
        </Container>
    </section>

    <section class="py-24 border-t border-white/5 bg-white/[0.01]">
        <Container>
            <div class="max-w-4xl mx-auto">
                <h2 class="text-3xl font-bold mb-12 flex items-center gap-4">
                    Open Positions
                    <span class="h-px flex-1 bg-white/5"></span>
                </h2>

                <div class="space-y-4">
                    {jobs.map((job) => (
                        <div class="p-6 bg-white/5 border border-white/5 rounded-2xl hover:border-cyan-400/30 transition-all duration-500 flex flex-col md:flex-row justify-between items-center gap-6 group">
                            <div class="text-center md:text-left">
                                <h4 class="text-xl font-bold text-white group-hover:text-cyan-400 transition-colors">
                                    {job.title}
                                    {job.hot && <span class="ml-2 text-[8px] bg-red-500/80 text-white px-2 py-0.5 rounded italic uppercase">Urgent</span>}
                                </h4>
                                <p class="text-xs text-gray-500 mt-1 uppercase tracking-widest">{job.city} • {job.type}</p>
                            </div>
                            <a href="#apply" class="px-8 py-2 border border-white/10 hover:border-cyan-400 hover:text-cyan-400 rounded-full text-sm font-bold transition-all">
                                Apply
                            </a>
                        </div>
                    ))}
                </div>
            </div>
        </Container>
    </section>

    <section id="apply" class="py-32">
        <Container>
            <div class="max-w-2xl mx-auto bg-white/5 border border-white/10 p-10 md:p-16 rounded-[2.5rem] shadow-2xl">
                <h3 class="text-2xl font-bold mb-10 text-center uppercase tracking-widest italic">Submit Application</h3>
                <form action="https://formspree.io/f/YOUR_ID" method="POST" enctype="multipart/form-data" class="space-y-6">
                    <input type="text" name="name" required placeholder="Full Name" class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white focus:border-cyan-400 outline-none transition" />
                    <input type="email" name="email" required placeholder="Email Address" class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white focus:border-cyan-400 outline-none transition" />
                    <select name="position" class="w-full bg-[#0a0a0a] border border-white/10 rounded-2xl px-6 py-4 text-white focus:border-cyan-400 outline-none transition font-bold uppercase text-xs">
                        {jobs.map(job => <option value={job.title}>{job.title}</option>)}
                    </select>
                    <input type="file" name="cv" accept=".pdf" required class="block w-full text-xs text-gray-400 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-bold file:bg-cyan-400 file:text-black cursor-pointer" />
                    <textarea name="message" rows="4" placeholder="Message..." class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white focus:border-cyan-400 outline-none transition resize-none"></textarea>
                    <button type="submit" class="w-full py-4 bg-cyan-400 hover:bg-white text-black font-black rounded-full transition-all duration-300 uppercase tracking-widest text-sm">
                        Submit
                    </button>
                </form>
            </div>
        </Container>
    </section>

  </main>
</Layout>
