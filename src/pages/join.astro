---
import Layout from '../layouts/Layout.astro';
import Container from '../components/Container.astro';

// ข้อมูลตำแหน่งงาน (จำลอง)
const jobs = [
    { title: "Cyber Security Instructor", city: "Bangkok", type: "Full-time", hot: true, desc: "ดูแลและพัฒนาหลักสูตรการสอนด้านความปลอดภัยไซเบอร์..." },
    { title: "AI/Full-Stack Developer", city: "Remote / BKK", type: "Full-time", hot: true, desc: "พัฒนา Platform และระบบ Simulation สำหรับการฝึกฝน..." },
    { title: "Content Creator (Cyber Literacy)", city: "Bangkok", type: "Full-time", hot: false, desc: "สร้างสรรค์สื่อดิจิทัลเพื่อสร้างความตระหนักรู้ด้านภัยไซเบอร์..." },
    { title: "Internship (Any Roles)", city: "Bangkok", type: "Intern", hot: false, desc: "เปิดรับนักศึกษาฝึกงานที่พร้อมเรียนรู้เทคโนโลยีใหม่ๆ..." },
];
---

<Layout title="Careers | GrowUpward 2026">
  <main class="bg-[#0a0a0a] min-h-screen text-white">
    
    <section class="relative h-[60vh] flex items-center justify-center overflow-hidden">
        <div class="absolute inset-0 z-0">
            <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&q=80" class="w-full h-full object-cover opacity-40" alt="Teamwork" />
            <div class="absolute inset-0 bg-gradient-to-b from-transparent to-[#0a0a0a]"></div>
        </div>
        
        <div class="relative z-10 text-center px-4">
            <h1 class="text-5xl md:text-7xl font-bold mb-6 tracking-tight">JOIN US <span class="text-cyan-400">GROW UPWARD</span></h1>
            <p class="text-xl text-gray-300 mb-8">Join us and make something people love</p>
            
            <div class="max-w-2xl mx-auto relative">
                <input type="text" placeholder="ค้นหาตำแหน่งงาน..." class="w-full bg-white/10 border border-white/20 backdrop-blur-md rounded-full py-4 px-8 outline-none focus:border-cyan-400 transition" />
                <button class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 hover:text-white">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                </button>
            </div>
        </div>
    </section>

    <section class="py-24">
        <Container>
            <h2 class="text-3xl font-bold text-center mb-16 italic font-mono uppercase tracking-tighter">Why GrowUpward</h2>
            <div class="grid grid-cols-1 md:grid-cols-4 gap-12 text-center">
                <div class="space-y-4">
                    <div class="text-4xl">💡</div>
                    <h3 class="font-bold text-lg text-white">Creativity First</h3>
                    <p class="text-sm text-gray-400 leading-relaxed">ให้โลกเห็นความคิดสร้างสรรค์ของคุณผ่านนวัตกรรม Cyber-Resilience</p>
                </div>
                <div class="space-y-4">
                    <div class="text-4xl">🌍</div>
                    <h3 class="font-bold text-lg text-white">Global Network</h3>
                    <p class="text-sm text-gray-400 leading-relaxed">ร่วมงานกับผู้เชี่ยวชาญระดับโลกในการสร้างความปลอดภัยทางดิจิทัล</p>
                </div>
                <div class="space-y-4">
                    <div class="text-4xl">📈</div>
                    <h3 class="font-bold text-lg text-white">Growth Mindset</h3>
                    <p class="text-sm text-gray-400 leading-relaxed">สนับสนุนการเรียนรู้และเติบโตด้วยทรัพยากรที่ยอดเยี่ยม</p>
                </div>
                <div class="space-y-4">
                    <div class="text-4xl">😊</div>
                    <h3 class="font-bold text-lg text-white">Work as Play</h3>
                    <p class="text-sm text-gray-400 leading-relaxed">วัฒนธรรมองค์กรที่ยืดหยุ่น สนุก และเต็มไปด้วยพลังงานบวก</p>
                </div>
            </div>
        </Container>
    </section>

    <section class="py-24 bg-white/5">
        <Container>
            <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6">
                <div>
                    <h2 class="text-4xl font-bold mb-4">Job Opportunities</h2>
                    <div class="flex gap-4">
                        <button class="text-cyan-400 border-b-2 border-cyan-400 pb-1">Social recruitment</button>
                        <button class="text-gray-500 hover:text-white transition pb-1">Campus recruitment</button>
                    </div>
                </div>
                <div class="flex gap-4">
                   <span class="px-4 py-1 bg-cyan-400/10 text-cyan-400 rounded-full text-sm border border-cyan-400/20">All Categories</span>
                   <span class="px-4 py-1 bg-white/5 text-gray-400 rounded-full text-sm border border-white/10 uppercase">Bangkok</span>
                </div>
            </div>

            <div class="divide-y divide-white/10 border-t border-b border-white/10">
                {jobs.map((job) => (
                    <div class="py-8 grid grid-cols-1 md:grid-cols-4 gap-6 items-center group hover:bg-white/5 transition px-4 rounded-xl">
                        <div class="md:col-span-1">
                            <h4 class="text-xl font-bold flex items-center gap-2">
                                {job.title}
                                {job.hot && <span class="text-[10px] bg-red-500 text-white px-1 rounded italic uppercase">Hot</span>}
                            </h4>
                            <p class="text-sm text-gray-500 mt-1">{job.city} | {job.type}</p>
                        </div>
                        <div class="md:col-span-2 text-sm text-gray-400">
                            {job.desc}
                        </div>
                        <div class="text-right">
                            <a href="#apply" class="inline-block border border-cyan-400 text-cyan-400 hover:bg-cyan-400 hover:text-black px-6 py-2 rounded-full transition font-bold text-sm">
                                Apply Now
                            </a>
                        </div>
                    </div>
                ))}
            </div>
        </Container>
    </section>

    <section id="apply" class="py-24 relative overflow-hidden">
        <div class="absolute inset-0 bg-cyan-400/5 blur-[120px] rounded-full -translate-y-1/2"></div>
        <Container>
            <div class="max-w-3xl mx-auto relative z-10">
                <div class="bg-white/5 border border-white/10 p-8 md:p-12 rounded-3xl backdrop-blur-xl">
                    <h3 class="text-2xl font-bold mb-8">Send Your CV</h3>
                    <form action="https://formspree.io/f/YOUR_ID" method="POST" enctype="multipart/form-data" class="space-y-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <input type="text" name="name" required placeholder="Full Name" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white focus:border-cyan-400 outline-none transition" />
                            <input type="email" name="email" required placeholder="Email Address" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white focus:border-cyan-400 outline-none transition" />
                        </div>
                        <select name="position" class="w-full bg-[#0a0a0a] border border-white/10 rounded-xl px-4 py-3 text-white focus:border-cyan-400 outline-none transition font-mono uppercase text-xs">
                            {jobs.map(job => <option value={job.title}>{job.title}</option>)}
                        </select>
                        <input type="file" name="cv" accept=".pdf" required class="block w-full text-sm text-gray-400 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-bold file:bg-cyan-400 file:text-black cursor-pointer" />
                        <textarea name="message" rows="4" placeholder="Tell us why you want to join..." class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white focus:border-cyan-400 outline-none transition resize-none"></textarea>
                        <button type="submit" class="w-full py-4 bg-cyan-400 hover:bg-cyan-300 text-black font-bold rounded-full transition-all duration-300">
                            Submit Application
                        </button>
                    </form>
                </div>
            </div>
        </Container>
    </section>

  </main>
</Layout>
