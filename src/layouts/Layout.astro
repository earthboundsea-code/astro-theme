---
import { AstroFont } from 'astro-font';
import AppFooter from "../components/AppFooter.astro";
import AppHeader from "../components/AppHeader.astro";
import "./../tailus.css"
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <meta name="description" content="GrowUpward - Protect security: a fundamental human necessity" />
        
        <title>GrowUpward 2026</title>

        <AstroFont
            config={[
                {
                    src: [],
                    name: "Urbanist",
                    preload: true,
                    display: "swap",
                    selector: "html",
                    fallback: "'Prompt', sans-serif", 
                    googleFontsURL: 'https://fonts.googleapis.com/css2?family=Urbanist:wght@400;500;600;700&display=swap',
                },
                {
                    src: [],
                    name: "Prompt",
                    preload: true,
                    display: "swap",
                    googleFontsURL: 'https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;700&display=swap',
                }
            ]}
        />

        <script is:inline>
            // ฟังก์ชันเริ่มต้นสำหรับ Google Translate
            function googleTranslateElementInit() {
                new google.translate.TranslateElement({
                    pageLanguage: 'en',
                    includedLanguages: 'en,th',
                    layout: google.translate.TranslateElement.InlineLayout.SIMPLE,
                    autoDisplay: false
                }, 'google_translate_element');
            }

            // ฟังก์ชันเปลี่ยนภาษาที่เสถียรขึ้น
            window.changeLanguage = function(langCode) {
                const tryChange = () => {
                    const selectEl = document.querySelector('.goog-te-combo');
                    if (selectEl) {
                        selectEl.value = langCode;
                        selectEl.dispatchEvent(new Event('change'));
                        // เซฟภาษาลงใน Cookie เผื่อไว้ให้ Google อ่าน
                        document.cookie = `googtrans=/en/${langCode}; path=/`;
                        document.cookie = `googtrans=/en/${langCode}; domain=.${window.location.hostname}; path=/`;
                    } else {
                        // ถ้ายังไม่เจอให้รออีกนิดแล้วลองใหม่
                        setTimeout(tryChange, 500);
                    }
                };
                tryChange();
            }
        </script>

        <script type="text/javascript" src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit" defer></script>

        <style is:global>
            /* ซ่อน UI ส่วนเกินของ Google */
            .goog-te-banner-frame.skiptranslate, 
            .goog-te-gadget-icon,
            #goog-gt-tt { display: none !important; }
            
            body { top: 0px !important; }
            
            .goog-te-gadget { 
                color: transparent !important; 
                font-size: 0px !important; 
            }
            
            #google_translate_element { display: none !important; }

            /* ปรับฟอนต์ให้เป็น Prompt ทันทีเมื่อหน้าเว็บถูกแปลเป็นไทย */
            html[lang="th"] body,
            body.translated-ltr {
                font-family: 'Prompt', 'Urbanist', sans-serif !important;
            }
        </style>
    </head>
    <body class="bg-white dark:bg-gray-950">
        <AppHeader />
        <slot />
        <div id="google_translate_element"></div>
        <AppFooter />
    </body>
</html>
